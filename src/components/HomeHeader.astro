---
import ResponsiveMenu from "@components/ResponsiveMenu.astro";
import leftWall from "@images/jbee_office_wall_left.svg";
import rightWall from "@images/jbee_office_wall_right.svg";
import workStation from "@images/jbee_office_workstation.svg";
import logo from "@images/logo_jbee_colors.svg";
import "@styles/global.css";
---

<header
  role="banner"
  class="parallax-header bg-background-header border-secondary relative z-10 box-border w-full overflow-hidden border-b-4">
  <div class="relative mx-auto h-[200px] max-w-7xl overflow-hidden lg:h-[400px]">
    <!-- 🔵 Mur (fond éloigné — vitesse 1/3) -->
    <img
      src={leftWall.src}
      alt=""
      class="parallax-wall absolute top-5 left-30 hidden max-h-[60%] object-cover lg:block"
    />
    <img
      src={rightWall.src}
      alt=""
      class="parallax-wall absolute right-5 bottom-0 hidden max-w-[500px] object-cover lg:block"
    />

    <!-- 🟢 Poste de travail (plan intermédiaire — vitesse 1/2) -->
    <img
      src={workStation.src}
      alt=""
      class="parallax-workstation absolute right-5 -bottom-10 hidden max-w-[500px] object-cover lg:block"
    />

    <!-- 🟡 Logo (premier plan — vitesse normale) -->
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="bg-offwhite/50 rounded p-4">
        <img src={logo.src} class="w-48 md:w-64" alt="Julien Bruneel développeur web - Retour à l'accueil" />
      </div>
    </div>
  </div>
</header>

<div class="mt-auto">
  <ResponsiveMenu isHomePage />
</div>

<style>
  /* Scroll-driven animations : Chrome/Edge/Safari uniquement.
     Sans ce @supports, animation-fill-mode: both décale les images vers le bas en Firefox
     car animation-timeline n'est pas pris en charge et animation-duration vaut 0s par défaut. */
  @supports (animation-timeline: scroll()) {
    .parallax-wall {
      animation-name: parallax-wall;
      animation-duration: 1ms;
      animation-timing-function: linear;
      animation-fill-mode: both;
      animation-timeline: scroll(root);
      animation-range: 0px 500px;
    }

    .parallax-workstation {
      animation-name: parallax-workstation;
      animation-duration: 1ms;
      animation-timing-function: linear;
      animation-fill-mode: both;
      animation-timeline: scroll(root);
      animation-range: 0px 500px;
    }
  }

  @keyframes parallax-wall {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(400px);
    }
  }

  @keyframes parallax-workstation {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(200px);
    }
  }
</style>

<script>
  if (!CSS.supports("animation-timeline", "scroll()")) {
    const walls = document.querySelectorAll<HTMLElement>(".parallax-wall");
    const workstations = document.querySelectorAll<HTMLElement>(".parallax-workstation");

    function updateParallax() {
      const progress = Math.min(window.scrollY / 500, 1);
      for (const el of walls) el.style.transform = `translateY(${progress * 400}px)`;
      for (const el of workstations) el.style.transform = `translateY(${progress * 200}px)`;
    }

    window.addEventListener("scroll", updateParallax, { passive: true });
    updateParallax();
  }
</script>
