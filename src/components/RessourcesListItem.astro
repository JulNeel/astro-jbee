---
import type { Ressource } from "@content/schemas/ressources.schema";
import { Image } from "astro:assets";

interface Props {
  ressource: Ressource;
}
const { ressource } = Astro.props;
---

<article class="group flex flex-col">
  <a href={ressource.link || "#"} target="_blank" rel="noopener noreferrer" class="flex flex-col">
    {
      ressource.thumbnail && (
        <div class="aspect-4/3 overflow-hidden">
          <Image
            src={ressource.thumbnail.smallUrl}
            alt={ressource.thumbnail.altText}
            width={500}
            height={500}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-120"
          />
        </div>
      )
    }

    <h3 class="h4 mt-2">{ressource.title}</h3>
    <div class="mt-3 flex items-center gap-2">
      {
        ressource.language && (
          <span class="rounded bg-blue-200 px-2 py-0.5 text-xs text-blue-600">{ressource.language}</span>
        )
      }
      {
        ressource.category && (
          <span class="rounded bg-gray-200 px-2 py-0.5 text-xs text-gray-600">{ressource.category}</span>
        )
      }

      {
        ressource.tags.length > 0 && (
          <div class="flex flex-wrap gap-1">
            {ressource.tags.map((tag) => (
              <span class="rounded bg-gray-200 px-2 py-0.5 text-xs text-gray-600">{tag}</span>
            ))}
          </div>
        )
      }
    </div>
    {ressource.description && <p class="text-foreground mt-1">{ressource.description}</p>}
  </a>
</article>
