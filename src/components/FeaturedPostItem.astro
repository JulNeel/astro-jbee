---
import type { Post } from "@content/schemas/posts.schema";
import { Image } from "astro:assets";

interface Props {
  post: Post;
}
const { post } = Astro.props;
---

<article class="group mb-12">
  <a href={`/${post.slug}`} class="grid gap-6 md:grid-cols-2 md:gap-8">
    {
      post.coverImage && (
        <div class="aspect-video overflow-hidden md:aspect-4/3">
          <Image
            src={post.coverImage.url}
            alt={post.coverImage.altText}
            width={800}
            height={600}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          />
        </div>
      )
    }
    <div class="flex flex-col justify-center">
      <span class="text-primary mb-2 text-sm font-semibold uppercase tracking-wide">Article à la une</span>
      <h2 class="h3 text-offblack group-hover:text-primary mb-3">{post.title}</h2>
      <time datetime={post.publishedDate.toISOString()} class="text-neutral-dark mb-4 text-sm">
        {post.publishedDate.toLocaleDateString("fr-FR", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      {post.excerpt && <p class="text-neutral-dark line-clamp-3">{post.excerpt}</p>}
    </div>
  </a>
</article>
